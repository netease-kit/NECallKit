{
  "name": "@xkit-yx/electron-callkit-vue3-uikit",
  "version": "4.7.0-rc.1",
  "description": "Electron CallKit Vue3 UIKit — 在 Electron 应用中接入 1v1 音视频通话的 Vue 3 UI 组件",
  "license": "MIT",
  "author": "",
  "keywords": [
    "electron",
    "callkit",
    "vue",
    "vue3",
    "video-call",
    "audio-call",
    "nim",
    "nertc",
    "webrtc",
    "yunxin"
  ],
  "homepage": "https://doc.yunxin.163.com/nertccallkit/concept",
  "bugs": {
    "url": "https://doc.yunxin.163.com/nertccallkit/concept"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/netease-kit/NECallKit.git"
  },
  "main": "src/index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./src/index.js",
      "default": "./src/index.js"
    },
    "./runtime-env": {
      "types": "./runtime-env.d.ts",
      "require": "./runtime-env.js",
      "default": "./runtime-env.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "runtime-env.js",
    "runtime-env.d.ts",
    "src",
    "index.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('./src/index.js'); require('./runtime-env.js')\""
  },
  "peerDependencies": {
    "electron": ">=25",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@xkit-yx/callkit-domain": "4.7.0-rc.1",
    "@xkit-yx/callkit-runtime-electron": "4.7.0-rc.1",
    "@xkit-yx/callkit-vue3-core": "4.7.0-rc.1",
    "@xkit-yx/electron-callkit-sdk": "4.7.0-rc.1"
  },
  "bundleDependencies": [
    "@xkit-yx/callkit-domain",
    "@xkit-yx/callkit-runtime-electron",
    "@xkit-yx/callkit-vue3-core",
    "@xkit-yx/electron-callkit-sdk"
  ]
}
