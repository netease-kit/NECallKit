page {
  height: 100%;
  width: 100%;
  overflow: hidden;
  background-color: #000;
}

.necall-container {
  position: fixed;
  top: 0;
  left: 0;
  height: 100vh;
  width: 100vw;
  z-index: 1;
  background-color: #1a1a23;
}

.necall-invite-container,
.necall-be-invited-container,
.necall-in-call-container {
  width: 100%;
  height: 100%;
  position: relative;
}

/* ===== 主叫呼叫中（居中布局，与被叫保持一致） ===== */
.necall-callee-info {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  top: 100px;
  color: #fff;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.necall-callee-avatar {
  width: 90px;
  height: 90px;
  border-radius: 8px;
}

.necall-callee-nickname {
  font-size: 20px;
  margin: 10px 0 5px;
}

.necall-callee-tips {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.7);
}

/* ===== 被叫来电 ===== */
.necall-caller-info {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  top: 100px;
  color: #fff;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.necall-caller-avatar {
  width: 90px;
  height: 90px;
  border-radius: 8px;
}

.necall-caller-nickname {
  margin: 10px 0 5px;
  font-size: 20px;
}

.necall-caller-tips {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.7);
}

/* ===== 呼叫/被叫底部按钮组 ===== */
.necall-calling-btn-group,
.necall-called-btn-group {
  padding: 0 20px;
  position: absolute;
  bottom: 60px;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  display: flex;
  justify-content: space-around;
  align-items: center;
  color: #fff;
  text-align: center;
}

.necall-btn .necall-img {
  display: block;
  margin: 0 auto 5px;
  width: 75px;
  height: 75px;
}

/* ===== 通话中 - 远端全屏视频 ===== */
.necall-remote-view {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: #292932;
  z-index: 1;
}

/* ===== 本地视频可拖动区域 ===== */
.necall-movable-area {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 20;
  pointer-events: none;
}

.necall-local-view-movable {
  width: 125px;
  height: 202px;
  pointer-events: auto;
}

.necall-local-view {
  width: 125px;
  height: 202px;
  background-color: #292932;
  border-radius: 8px;
  overflow: hidden;
}

/* ===== 通话中 - 语音通话界面 ===== */
.necall-in-call-audio {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  top: 120px;
  color: #fff;
  text-align: center;
}

.necall-in-call-avatar {
  width: 90px;
  height: 90px;
  border-radius: 8px;
}

.necall-in-call-title {
  margin: 10px 0 5px;
  font-size: 20px;
}

.necall-in-call-tips {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.7);
}

/* ===== 视频通话时长（顶部居中，z-index高于视频层） ===== */
.necall-in-call-duration {
  position: absolute;
  top: 50px;
  left: 50%;
  transform: translateX(-50%);
  color: #fff;
  z-index: 30;
  font-size: 14px;
  background-color: rgba(0, 0, 0, 0.3);
  padding: 4px 12px;
  border-radius: 20px;
}

.necall-in-call-video-mute-tips {
  position: absolute;
  text-align: center;
  width: 100%;
  top: 50%;
  transform: translateY(-50%);
  color: #fff;
  font-size: 20px;
  z-index: 5;
}

/* ===== 通话中底部操作按钮（z-index高于本地视频） ===== */
.necall-in-call-btn-group {
  padding: 0 20px;
  position: absolute;
  bottom: 50px;
  left: 50%;
  transform: translateX(-50%);
  width: 224px;
  height: 60px;
  background: linear-gradient(180deg, #393947 6.82%, #292933 99.71%);
  box-shadow: inset 0px 1px 0px rgba(255, 255, 255, 0.0983938);
  border-radius: 30px;
  display: flex;
  justify-content: space-around;
  align-items: center;
  z-index: 25;
}

.necall-microphone-btn {
  width: 24px;
  height: 24px;
}

.necall-camera-revert-btn {
  width: 24px;
  height: 24px;
}

.necall-video-btn {
  width: 24px;
  height: 24px;
}

.necall-hangup-btn {
  width: 32px;
  height: 32px;
}
